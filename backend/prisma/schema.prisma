generator client {
  provider = "prisma-client-js"
}

// In Prisma 6 config is partially moved, but we still define the datasource here for compatibility and standard Prisma Client.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  FREELANCER
  CLIENT
  ADMIN
}

enum ProjectStatus {
  PENDING_APPROVAL
  OPEN
  STAGE_1_EVALUATION
  STAGE_2_OPEN
  STAGE_2_EVALUATION
  COMPLETED
}

model User {
  id                     String           @id @default(uuid())
  name                   String
  email                  String           @unique
  password               String
  role                   Role
  
  // Blostem Simulation (Synthetic Data)
  kyc_verified           Boolean          @default(false)
  account_balance        Float            @default(0)
  payment_capacity_score Int              @default(50)

  projects               Project[]        @relation("ClientProjects")
  submissions            Submission[]
  profileHistories       ProfileHistory[]
}

model Project {
  id              String         @id @default(uuid())
  title           String
  description     String
  budget          Float
  status          ProjectStatus  @default(PENDING_APPROVAL)
  client          User           @relation("ClientProjects", fields: [clientId], references: [id])
  clientId        String
  submissions     Submission[]
  profileHistory  ProfileHistory[]
  createdAt       DateTime       @default(now())
}

model Submission {
  id           String    @id @default(uuid())
  project      Project   @relation(fields: [projectId], references: [id])
  projectId    String
  user         User      @relation(fields: [userId], references: [id])
  userId       String
  stage        Int       // 1 or 2
  mvpLink      String
  architecture String
  plan         String
  score        Int?      // 0-100
  status       String    @default("PENDING") // PENDING, SHORTLISTED, REJECTED, WINNER
  feedback     Feedback?
  createdAt    DateTime  @default(now())
}

model Feedback {
  id           String     @id @default(uuid())
  submission   Submission @relation(fields: [submissionId], references: [id])
  submissionId String     @unique
  text         String
}

model ProfileHistory {
  id           String    @id @default(uuid())
  user         User      @relation(fields: [userId], references: [id])
  userId       String
  project      Project   @relation(fields: [projectId], references: [id])
  projectId    String
  stageReached Int       // 1 or 2 or 3 (Winner)
  createdAt    DateTime  @default(now())
}
